# Companion Duck brain configuration. Copy to .env and edit.
# All settings are prefixed DUCK_ and read by duckbrain/config.py.

# --- Model paths (no models are downloaded in Stage 0) ---
DUCK_LLM_MODEL_PATH=models/gemma4-e2b
DUCK_STT_MODEL_PATH=models/parakeet
DUCK_TTS_MODEL_PATH=models/kokoro

# --- Audio device IDs (sounddevice indices; leave blank for system default) ---
DUCK_INPUT_DEVICE=
DUCK_OUTPUT_DEVICE=

# --- Brain bus (WebSocket) ---
DUCK_BRAIN_HOST=127.0.0.1
DUCK_BRAIN_PORT=8765

# --- Local data directory (resident profiles, conversation logs) ---
DUCK_DATA_DIR=data
